# ===========================================
# AgentArena - Environment Configuration
# ===========================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# Then set up the database:
#   npx prisma migrate dev --name init
#   npm run seed        (optional: populates 10 starter problems)
#
# Start the dev server:
#   npm run dev
# ===========================================

# Database - Neon PostgreSQL (free at https://neon.tech)
# Get your connection string from the Neon dashboard
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Piston API - Code execution engine
# Free public API (default). Or self-host with Docker:
#   docker run -d --name piston -p 2000:2000 ghcr.io/engineer-man/piston
PISTON_URL="https://emkc.org/api/v2/piston"

# Anthropic API Key - For AI code evaluation (scoring)
# Get yours at: https://console.anthropic.com/
# If not set, submissions will be scored on correctness only (no AI quality score)
ANTHROPIC_API_KEY=""

# Admin Key - Required to access the admin panel (approve/reject problems)
# Generate one with: openssl rand -hex 32
ADMIN_KEY=""
